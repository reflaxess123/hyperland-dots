{
  "layer": "top",
  "position": "top",
  "margin-top": 10,
  "margin-bottom": -10,
  "modules-left": [
    "custom/launcher",
    "cpu",
    "custom/cpu-temp",
    "custom/gpu-temp",
    "custom/fan",
    "memory",
    "disk",
    "network",
    "tray"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "hyprland/language",
    "bluetooth",
    "pulseaudio",
    "custom/mic-volume",
    "pulseaudio/slider",
    "clock",
    "custom/power"
  ],
  "hyprland/language": {
    "format-us": "US",
    "format-ru": "RU"
  },
  "pulseaudio": {
    "tooltip": false,
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-muted": "{icon} {volume}%",
    "on-click": "pavucontrol",
    "format-icons": {
      "default": [
        "ÔÄ¶",
        "ÔÄß",
        "ÔÄ®"
      ]
    }
  },
  "pulseaudio/slider": {
    "min": 0,
    "max": 100,
    "orientation": "horizontal",
    "expand": false
  },
  "network": {
    "format-wifi": "Ôáę {essid}",
    "format-ethernet": "ůįąÄ Connected",
    "tooltip-format": "{essid} ({signalStrength}%)",
    "format-linked": "{ifname} (No IP) ",
    "format-disconnected": "ůįĆô Disconnected",
    "format-alt": "{ifname}: {ipaddr}/{cidr}"
  },
  "bluetooth": {
    "format": "ÔäĒ {status}",
    "on-click": "blueman-manager",
    "format-disabled": "",
    "format-connected": "ÔäĒ {num_connections} connected",
    "tooltip-format": "{controller_alias} {controller_address}"
  },
  "tray": {
    "icon-size": 18,
    "spacing": 10
  },
  "clock": {
    "format": "ÔÄó {:%H:%M %d/%m/%Y}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "cpu": {
    "interval": 15,
    "format": "Ôčõ {}%",
    "max-length": 10
  },
  "custom/cpu-temp": {
    "exec": "sensors k10temp-pci-00c3 | grep 'Tctl:' | awk '{print $2}' | sed 's/+//;s/¬įC//'",
    "format": "ÔčČ {}¬įC",
    "interval": 5
  },
  "custom/gpu-temp": {
    "exec": "nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits",
    "format": "GPU: {}¬įC",
    "interval": 5
  },
  "custom/fan": {
    "exec": "sensors asusec-isa-000a | grep 'Chipset:' | awk 'NR==1{print $2}'",
    "format": "Ô°£ {} RPM",
    "interval": 5
  },
  "memory": {
    "interval": 30,
    "format": "ÔĒł {}%",
    "max-length": 10
  },
  "disk": {
    "interval": 30,
    "format": "Ôā† {percentage_used}%",
    "path": "/"
  },
  "custom/launcher": {
    "format": "",
    "on-click": "rofi -show drun",
    "on-click-right": "killall rofi"
  },
  "custom/power": {
    "format": "‚ŹĽ",
    "on-click": "bash ~/.config/waybar/scripts/leave.sh",
    "tooltip": "Power Menu"
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "on-click": "activate",
    "format-icons": {
      "1": "‚óŹ",
      "2": "‚óŹ",
      "3": "‚óŹ",
      "4": "‚óŹ",
      "5": "‚óŹ",
      "6": "‚óŹ",
      "7": "‚óŹ",
      "8": "‚óŹ",
      "9": "‚óŹ",
      "10": "‚óŹ",
      "active": "‚óŹ",
      "default": "‚óŹ"
    }
  }
}
